
// FRONTEND
{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "ESNext",

    "lib": ["DOM", "ES2020"],

    "jsx": "react-jsx",

    "sourceMap": true,

    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "isolatedModules": true,
    "skipLibCheck": true,

    "noEmitOnError": true,
    "removeComments": true
  },
  "include": ["src/**/*"]
}
    